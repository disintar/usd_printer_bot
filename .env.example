# Database
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres.openclaw.svc.cluster.local
POSTGRES_PORT=5432

# Django
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=

# Logging
LOG_LEVEL=INFO

# Financial Data (FMP)
FMP_ENABLED=true
FMP_API_KEY=

# Price Cron
PRICE_CRON_ENABLED=true
PRICE_CRON_INTERVAL_SECONDS=60

# Test Time Warp
TEST_TIME_WARP_ENABLED=false
TEST_TIME_WARP_INTERVAL_SECONDS=1

# MCP (Market Context Protocol)
MCP_ENABLED=false
MCP_SERVER_URL=
MCP_TIMEOUT_SECONDS=10
MCP_PROTOCOL_VERSION=2025-03-26

# LLM (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimax.io/v1
OPENAI_MODEL=MiniMax-M2.1
OPENAI_TIMEOUT_SECONDS=20

# Telegram Bot
TELEGRAM_BOT_TOKEN=
BACKEND_URL=http://localhost:8000
